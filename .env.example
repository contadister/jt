# ─────────────────────────────────────────
# JOSETT — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to GitHub
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Josett

# ── Supabase ─────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database ─────────────────────────────
# Get from: supabase.com → your project → Settings → Database → Connection string (URI)
DATABASE_URL=
# Direct URL (for Prisma migrations)
DIRECT_URL=

# ── Paystack ─────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ── Arkesel (Email + SMS) ─────────────────
# Get from: arkesel.com → Dashboard → API Keys
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=Josett

# ── GitHub ────────────────────────────────
# Create at: github.com → Settings → Developer Settings → Personal Access Tokens
# Token needs: repo (full control), delete_repo
GITHUB_TOKEN=
GITHUB_ORG=josett-sites

# ── Vercel ────────────────────────────────
# Get from: vercel.com → Account Settings → Tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ── Supabase Storage ──────────────────────
# Storage bucket name (create in Supabase dashboard)
SUPABASE_STORAGE_BUCKET=josett-uploads

# ── Security ──────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
CRON_SECRET=

# ── Ads ───────────────────────────────────
# Your Google AdSense Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=

# ── Unsplash (free stock photos in builder) ───
# Get from: unsplash.com/oauth/applications
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=
